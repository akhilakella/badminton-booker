      const allBooked = namedCount > 0 && bookedCount === namedCount;
      const noneBooked = bookedCount === 0;
      const statusClass = allBooked ? 'all' : noneBooked ? 'none' : 'partial';
      const statusText = allBooked ? 'All booked' : noneBooked ? 'Not booked' : 'Partially booked';
      const card = document.createElement('div');
      card.className = 'slot-card' + (allBooked ? ' all-booked' : '');
      card.style.marginBottom = '10px';
      const playersHTML = slot.players.map((p, pi) => {
        const hasName = !!p.name;
        const c = hasName ? color(p.name) : '#3a3a4a';
        const statusTxt = p.booked && p.court ? 'Court ' + p.court : p.booked ? 'Booked' : hasName ? 'Not booked yet' : 'Tap to assign';
        return '<div class="player' + (p.booked?' booked':'') + (!hasName?' empty':'') + '" onclick="currentDay=&quot;' + day + '&quot;;openSingleModal(' + i + ',' + pi + ')">'
          + '<div class="avatar" style="background:' + c + (hasName?'22':'44') + ';color:' + (hasName?c:'#555') + '">' + initials(p.name) + '</div>'
          + '<div class="player-info"><div class="player-name" style="' + (!hasName?'color:var(--muted);font-weight:400':'') + '">' + (hasName ? p.name : 'Tap to assign') + '</div>'
          + '<div class="player-status">' + statusTxt + '</div></div>'
          + '<div class="check-icon"><svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div></div>';
      }).join('');
      const courts = slot.players.filter(p=>p.booked&&p.court).map(p=>p.court);
      const uniqueCourts = [...new Set(courts)];
      let courtBadgeHTML = '';
      if (uniqueCourts.length === 1 && courts.length >= 1) {
        courtBadgeHTML = '<div class="court-badge"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.2"/><line x1="6" y1="1" x2="6" y2="11" stroke="currentColor" stroke-width="1.2"/><line x1="1" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.2"/></svg>Court ' + uniqueCourts[0] + '</div>';
      } else if (uniqueCourts.length > 1) {
        courtBadgeHTML = '<div class="court-badge" style="background:rgba(239,159,39,0.1);border-color:rgba(239,159,39,0.3);color:var(--warn)">Courts ' + uniqueCourts.join(' & ') + '</div>';
      }
      card.innerHTML = '<div class="slot-top"><div class="slot-time-wrap"><div class="slot-label">Court slot</div><div class="slot-time">' + slot.time + '</div></div><div class="slot-status ' + statusClass + '">' + statusText + '</div></div><div class="slot-players">' + playersHTML + '</div>' + courtBadgeHTML;
      container.appendChild(card);
    });
  });
}

function renderAtt() {
  const container = document.getElementById('att-page');
  container.innerHTML = '';
  ['monday','wednesday','thursday'].forEach(day => {
    const date = getNextDay(day);
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const dateStr = ordinal(date.getDate()) + ' ' + months[date.getMonth()];
    const header = document.createElement('div');
    header.className = 'att-day-header';
    header.innerHTML = day.charAt(0).toUpperCase()+day.slice(1) + '<span>' + dateStr + '</span>';
    container.appendChild(header);
    const card = document.createElement('div');
    card.className = 'att-card';
    if (!attState[day]) attState[day] = {};
    ATT_MEMBERS.forEach(function(m) {
      const present = attState[day][m.name] || false;
      const row = document.createElement('div');
      row.className = 'att-row';
      const ini = m.name.slice(0,2).toUpperCase();
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.checked = present;
      checkbox.addEventListener('change', (function(d, n) {
        return function(e) { toggleAtt(d, n, e.target.checked); };
      })(day, m.name));
      const toggleLabel = document.createElement('label');
      toggleLabel.className = 'toggle';
      toggleLabel.appendChild(checkbox);
      const slider = document.createElement('span');
      slider.className = 'toggle-slider';
      toggleLabel.appendChild(slider);
      row.innerHTML = '<div class="att-name">'
        + '<div class="att-avatar" style="background:' + m.color + '22;color:' + m.color + '">' + ini + '</div>'
        + '<div class="att-label">' + m.name + '<span>' + (present ? 'Present' : 'Absent') + '</span></div>'
        + '</div>';
      row.appendChild(toggleLabel);
      card.appendChild(row);
    });
    container.appendChild(card);
  });
}

function toggleAtt(day, name, val) {
  if (!attState[day]) attState[day] = {};
  attState[day][name] = val;
  saveAttState(day, name, val);
  renderAtt();
}

function makeDefaultAttState() {
  const s = {};
  ['monday','wednesday','thursday'].forEach(day => {
    s[day] = {};
    ATT_MEMBERS.forEach(m => s[day][m.name] = false);
  });
  return s;
}

async function loadAttState() {
  try {
    const r = await fetch('/api/attendance');
    attState = await r.json();
  } catch(e) {
    attState = makeDefaultAttState();
  }
}

async function saveAttState(day, name, val) {
  try {
    await fetch('/api/attendance', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ day, name, present: val })
    });
  } catch(e) { console.error('Att save failed', e); }
}

function openSingleModal(slotIdx, playerIdx) {
  editingSlot = slotIdx;
  editingPlayer = playerIdx;
  const slot = state[currentDay][slotIdx];
  const p = slot.players[playerIdx];
  const label = playerIdx === 0 ? 'Player 1' : 'Player 2';
  document.getElementById('single-modal-title').textContent = label + ' - ' + slot.time;
  document.getElementById('single-modal-sub').textContent = 'Select name and court number';
  document.getElementById('single-name').value = p.name || '';
  document.getElementById('single-court').value = p.court || '';
  document.getElementById('single-modal-bg').classList.add('open');
}

function closeSingleModal(e) {
  if (e && e.target !== document.getElementById('single-modal-bg')) return;
  document.getElementById('single-modal-bg').classList.remove('open');
  editingSlot = null; editingPlayer = null;
}

function saveSingleModal() {
  const name = document.getElementById('single-name').value;
  const court = document.getElementById('single-court').value;
  const p = state[currentDay][editingSlot].players[editingPlayer];
  p.name = name; p.court = court || null; p.booked = name !== '' && court !== '';
  document.getElementById('single-modal-bg').classList.remove('open');
  const savedSlot = editingSlot; const savedPlayer = editingPlayer; const savedDay = currentDay;
  editingSlot = null; editingPlayer = null;
  if (weekView) { renderWeek(); } else { render(); }
  savePlayer(savedDay, savedSlot, savedPlayer);
  const msg = p.booked ? name + ' booked - Court ' + court : name ? name + ' assigned' : 'Slot cleared';
  showToast(msg);
}

function clearSinglePlayer() {
  const p = state[currentDay][editingSlot].players[editingPlayer];
  p.name = ''; p.booked = false; p.court = null;
  document.getElementById('single-modal-bg').classList.remove('open');
  const savedSlot = editingSlot; const savedPlayer = editingPlayer; const savedDay = currentDay;
  editingSlot = null; editingPlayer = null;
  if (weekView) { renderWeek(); } else { render(); }
  savePlayer(savedDay, savedSlot, savedPlayer);
  showToast('Spot cleared');
}

function confirmReset() {
  if (confirm('Reset all bookings for this week?')) {
    state = makeDefaultState();
    saveData().then(() => { updateTabDates(); render(); showToast('All bookings reset'); });
  }
}

function shareWhatsApp() {
  if (!state) return;
  const date = getNextDay(currentDay);
  const dayLabel = formatDate(date);
  const slots = state[currentDay];
  let msg = '&#127992; *Court Booker - ' + dayLabel + '*\n';
  msg += "Queen's Diamond Jubilee Centre\n\n";
  slots.forEach(slot => {
    msg += '*' + slot.time + '*\n';
    slot.players.forEach(p => {
      if (p.name) {
        const courtTxt = p.court ? ' - Court ' + p.court : ' - not booked yet';
        msg += (p.booked ? '\u2705' : '\u23F3') + ' ' + p.name + courtTxt + '\n';
      } else { msg += '\u2795 Empty slot\n'; }
    });
    msg += '\n';
  });
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

function shareWeekWhatsApp() {
  if (!state) return;
  let msg = "&#127992; *Court Booker - This Week*\n";
  msg += "Queen's Diamond Jubilee Centre\n\n";
  ['monday','wednesday','thursday'].forEach(day => {
    const date = getNextDay(day);
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const dateStr = ordinal(date.getDate()) + ' ' + months[date.getMonth()];
    msg += '*' + day.charAt(0).toUpperCase()+day.slice(1) + ' ' + dateStr + '*\n';
    state[day].forEach(slot => {
      msg += '_' + slot.time + '_\n';
      slot.players.forEach(p => {
        if (p.name) {
          const courtTxt = p.court ? ' - Court ' + p.court : ' - not booked yet';
          msg += (p.booked ? '\u2705' : '\u23F3') + ' ' + p.name + courtTxt + '\n';
        } else { msg += '\u2795 Empty slot\n'; }
      });
    });
    msg += '\n';
  });
  window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
}

function toggleTheme() {
  const isLight = document.documentElement.classList.toggle('light');
  document.getElementById('theme-toggle').textContent = isLight ? '\uD83C\uDF11' : '\uD83C\uDF19';
  document.querySelector('meta[name="theme-color"]').setAttribute('content', isLight ? '#f4f4f0' : '#0f0f13');
  localStorage.setItem('theme', isLight ? 'light' : 'dark');
}

function initTheme() {
  const saved = localStorage.getItem('theme');
  if (saved === 'light') {
    document.documentElement.classList.add('light');
    document.getElementById('theme-toggle').textContent = '\uD83C\uDF11';
    document.querySelector('meta[name="theme-color"]').setAttribute('content', '#f4f4f0');
  }
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.classList.remove('show'), 2200);
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(()=>{});
}

initTheme();
checkAutoReset();
loadData();
loadAttState().then(() => { if (attView) renderAtt(); });

setInterval(async () => {
  try {
    const r = await fetch('/api/bookings');
    state = await r.json();
    if (weekView) { renderWeek(); } else if (!attView) { render(); }
    const a = await fetch('/api/attendance');
    attState = await a.json();
    if (attView) renderAtt();
  } catch(e) {}
}, 30000);
</script>
</body>
